# Copy to env.local or .env.local in this folder. Do not commit secrets.
# Prefer setting Supabase once in the project root .env (same as VITE_SUPABASE_*).
# If you use this file: use the SAME Project URL as VITE_SUPABASE_URL. Leave a key out entirely rather than SUPABASE_URL= (empty).

LUMA_API_KEY=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here
# SUPABASE_STORAGE_BUCKET=user-assets
