# ⚠️ IMPORTANT: Add this file to .gitignore!
# Do NOT commit this file to version control

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Hugging Face AI API
VITE_HUGGINGFACE_API_KEY=hf_your_real_api_key_here

# Toss Payments (Test Mode)
VITE_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
VITE_TOSS_SECRET_KEY=test_sk_your_secret_key_here

# Toss Payments (Production Mode - Use when deploying)
# VITE_TOSS_CLIENT_KEY=live_ck_your_production_key_here
# VITE_TOSS_SECRET_KEY=live_sk_your_secret_key_here

# Supabase (Eternal Beam 백엔드: 콘텐츠·슬롯·기기 API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 서버 전용 (device slots API 등) - Supabase 대시보드 → Settings → API → service_role
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Luma Dream Machine API (Image-to-Video) - https://lumalabs.ai/
LUMA_API_KEY=your_luma_api_key_here

# Modal GPU (배경 제거 15초 내 처리) - modal.com
# modal token new 로 발급 후 설정. 없으면 로컬 CPU 사용
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret
# MODAL_GPU=T4  # 또는 A10G (배포 시 Modal Secret으로 설정 가능)

# App Environment
VITE_APP_ENV=development
