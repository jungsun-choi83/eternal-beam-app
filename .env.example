# ⚠️ IMPORTANT: Add this file to .gitignore!
# Do NOT commit this file to version control

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Hugging Face AI API
VITE_HUGGINGFACE_API_KEY=hf_your_real_api_key_here

# Toss Payments (Test Mode)
VITE_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
VITE_TOSS_SECRET_KEY=test_sk_your_secret_key_here

# Toss Payments (Production Mode - Use when deploying)
# VITE_TOSS_CLIENT_KEY=live_ck_your_production_key_here
# VITE_TOSS_SECRET_KEY=live_sk_your_secret_key_here

# Supabase — 프론트·Node·Python이 **같은 프로젝트**를 쓰도록 한 세트로 맞춤 (예전 URL/키가 남아 있으면 전부 교체)
# Dashboard → Settings → API: Project URL = VITE_SUPABASE_URL = SUPABASE_URL (세 곳 모두 동일 문자열)
# anon / publishable 키 → VITE_SUPABASE_ANON_KEY (브라우저). service_role JWT → SUPABASE_SERVICE_ROLE_KEY (서버만, 절대 프론트에 넣지 않음)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt_here

# Vercel 배포: 위 네 줄을 Production/Preview 환경 변수에도 동일하게 추가. Luma 파이프라인은 SUPABASE Storage 공개 URL이 필요함.
# npm run video-api: 루트 .env 를 읽음. backend/.env.local 에 빈 SUPABASE_URL= 만 두면 안 됨(덮어쓰기 방지 로직 적용됨).

# Storage 버킷 (기본 user-assets). 없으면 Dashboard → Storage 에서 생성.
# SUPABASE_STORAGE_BUCKET=user-assets

# Luma Dream Machine API (Image-to-Video) - https://lumalabs.ai/
LUMA_API_KEY=your_luma_api_key_here

# Modal GPU (배경 제거 15초 내 처리) - modal.com
# modal token new 로 발급 후 설정. 없으면 로컬 CPU 사용
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret
# MODAL_GPU=T4  # 또는 A10G (배포 시 Modal Secret으로 설정 가능)

# App Environment
VITE_APP_ENV=development
